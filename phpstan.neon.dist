includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
        - tests
    level: 8
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    parallel:
        maximumNumberOfProcesses: 1
    ignoreErrors: []
    excludePaths:
        - vendor/*
        - tests/*/vendor/*
        - tests/*/Fixtures/*
        - tests/Architecture/*
    # TODO(Фаза 1, ROADMAP §"Архитектурные правила в PHPStan"):
    #   custom rule forbidding `Illuminate\Database\Eloquent\Model` references
    #   inside `Application/UseCases/*` to keep UseCases storage-agnostic.
    #   Implementation deferred — Фаза 0 only configures the analyzer.
