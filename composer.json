{
  "name": "dimitrienkov0/laravel-modules",
  "description": "Manifest-driven Laravel module loader and lifecycle toolkit.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "DimitrienkoV\\LaravelModules\\": "src/",
      "DimitrienkoV\\LaravelModules\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Dimitrienko Vadim",
      "email": "dimitrienkov0@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.3",
    "composer/semver": "^3.4",
    "ext-mbstring": "*",
    "ext-zip": "*",
    "laravel/framework": "^12|^13",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2",
    "friendsofphp/php-cs-fixer": "^3.65",
    "inertiajs/inertia-laravel": "^2",
    "larastan/larastan": "^3",
    "mockery/mockery": "^1.2",
    "moonshine/moonshine": "^4.0",
    "orchestra/testbench": "^10|^11",
    "pestphp/pest": "^3",
    "pestphp/pest-plugin-arch": "^3",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^11|^12",
    "rector/rector": "^2",
    "tomasvotruba/type-coverage": "^2.2"
  },
  "suggest": {
    "inertiajs/inertia-laravel": "Required only for loading module Routes/inertia.php files in Inertia host applications.",
    "moonshine/moonshine": "Required only for the MoonShine admin UI (modules resource, index/form/detail pages, menu autoload). Provides the full v4 CRUD/UI/Laravel stack."
  },
  "extra": {
    "laravel": {
      "providers": [
        "DimitrienkoV\\LaravelModules\\Providers\\ModuleLoaderServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "test:arch": "vendor/bin/pest --testsuite=Architecture",
    "test:unit": "vendor/bin/phpunit --testsuite=Unit",
    "test:feature": "vendor/bin/phpunit --testsuite=Feature",
    "test": [
      "@test:arch",
      "@test:unit",
      "@test:feature"
    ],
    "test:bail": "vendor/bin/pest --bail",
    "rector": "vendor/bin/rector process",
    "rector:dry": "vendor/bin/rector process --dry-run",
    "rector:fresh": "vendor/bin/rector process --clear-cache",
    "rector:debug": "vendor/bin/rector process --dry-run --debug",
    "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
    "format:dry": "vendor/bin/php-cs-fixer fix --allow-risky=yes --dry-run --diff",
    "phpstan": "vendor/bin/phpstan analyse --memory-limit=1G",
    "phpstan:debug": "vendor/bin/phpstan analyse --memory-limit=1G --debug",
    "phpstan:clear": [
      "vendor/bin/phpstan clear-result-cache",
      "vendor/bin/phpstan analyse --memory-limit=1G"
    ]
  }
}
